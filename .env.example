ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Publicación en Meta (Instagram/Facebook): NO son variables de entorno — cada marca guarda
# su propio meta_page_id / meta_ig_user_id / meta_page_access_token en la tabla brands.
METRICOOL_USER_TOKEN=
METRICOOL_USER_ID=
RESEND_API_KEY=
WEEKLY_REPORT_TO=          # email que recibe el reporte semanal (o lista separada por comas)
WEEKLY_REPORT_FROM=        # ej. "Auto Post <reportes@tudominio.com>" — dominio debe estar verificado en Resend
APP_PASSWORD_HASH=         # hash bcrypt de la contraseña del dashboard (generar con bcryptjs, nunca la contraseña en texto plano)
APP_SESSION_SECRET=        # string aleatorio largo, firma los tokens de sesión emitidos por /api/login
MCP_API_TOKEN=             # credencial fija para el servidor MCP (/api/mcp) — se pega como Bearer token al agregar el custom connector en Claude.ai/Cowork

# Netlify DB (Postgres) y Netlify Blobs se auto-provisionan al hacer deploy —
# no requieren variables de entorno manuales (ver @netlify/database).
